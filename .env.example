# ============================================
# BEARBET TRACKER - Configuração de Ambiente
# ============================================

# Servidor
PORT=3001
NODE_ENV=production

# Atrás de proxy reverso (Coolify, Traefik, Nginx) — use true em produção com HTTPS
TRUST_PROXY=true

# Container / Coolify: rodar seed no startup (só no 1º deploy; depois remova ou defina false)
# RUN_SEED=false

# Container: pular migrações no entrypoint (debug)
# SKIP_MIGRATIONS=false

# Banco de Dados PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bearbet_tracker
DB_USER=bearbet
DB_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_AQUI

# Meta / Facebook CAPI
META_PIXEL_ID=SEU_PIXEL_ID_AQUI
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
META_API_VERSION=v19.0
META_TEST_EVENT_CODE=

# Segurança
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_AQUI
WEBHOOK_SECRET_XGATE=CHAVE_SECRETA_XGATE
WEBHOOK_SECRET_CASSINO=CHAVE_SECRETA_CASSINO

# Redis (para filas)
REDIS_HOST=redis
REDIS_PORT=6379

# Modo Debug (true/false)
DEBUG_MODE=false

# URL base do sistema
BASE_URL=https://track.bearbet.com

# Portas do Nginx no docker-compose são fixas 8080/8443 (Coolify). VPS na 80/443: edite docker-compose.yml.
